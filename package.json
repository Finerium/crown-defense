{
  "name": "crown-defense",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": { "node": ">=22" },
  "description": "Crown Defense — bank-grade autonomous ransomware defense (closed-loop AI agent).",
  "license": "Apache-2.0",
  "scripts": {
    "typecheck": "tsc -b",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose up -d db && node scripts/wait-for-db.mjs",
    "db:down": "docker compose down",
    "db:migrate": "node scripts/migrate.mjs",
    "gate1:evidence": "tsx scripts/gate1-evidence.ts",
    "gate2:evidence": "tsx scripts/gate2-evidence.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@crown/agent": "workspace:*",
    "@crown/audit": "workspace:*",
    "@crown/containment": "workspace:*",
    "@crown/contracts": "workspace:*",
    "@crown/control-plane": "workspace:*",
    "@crown/detection": "workspace:*",
    "@crown/simulator": "workspace:*",
    "@crown/test-infra": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  }
}
