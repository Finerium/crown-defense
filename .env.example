# Crown Defense — environment template. Copy to .env and fill. NEVER commit the real .env.
# 12-factor: all config env-driven (AC-CONFIG). The dial default + detection thresholds are config, not literals.

# --- Data stores (ADR-013: the two stores are kept separate) ---
OPERATIONAL_DB_URL=postgresql://crowndefense:crowndefense@localhost:5432/crowndefense_operational
AUDIT_DB_URL=postgresql://crowndefense:crowndefense@localhost:5432/crowndefense_audit

# --- Signing secrets (generate each with: openssl rand -hex 32) ---
CONTROL_PLANE_TOKEN_SECRET=replace-me-openssl-rand-hex-32
AUDIT_INTEGRITY_KEY=replace-me-openssl-rand-hex-32

# --- LLM (DEV/TEST ONLY — never the production answer; ADR-002 mandates self-hosted on-prem in production) ---
# DeepSeek is OpenAI-API-compatible. The model-agnostic abstraction makes the prod swap a config change.
DEEPSEEK_API_KEY=sk-replace-me
LLM_API_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro

# --- Autonomy (shipped + pilot default is MONITOR_ONLY; full-auto is never the default) ---
CROWN_DIAL_DEFAULT=MONITOR_ONLY

# --- Detection thresholds (@crown/detection config.ts ENV_KEYS — names verified by a drift test) ---
# SAFETY: CROWN_DET_MIN_CORROBORATION is clamped to >=2 and CROWN_DET_WINDOW to >=1 (cannot be weakened).
CROWN_DET_ENTROPY_DELTA=1.5
CROWN_DET_ENTROPY_LOW_BASE=6.0
CROWN_DET_ENTROPY_HIGH=7.5
CROWN_DET_OPFREQ_WRITES=50
CROWN_DET_OPFREQ_RENAMES=20
CROWN_DET_OPFREQ_CUMULATIVE=8
CROWN_DET_FORMAT_FAIL_MIN=2
CROWN_DET_TYPE_HEADER_MIN=2
CROWN_DET_ENTROPY_MIN=2
CROWN_DET_WINDOW=256
CROWN_DET_MIN_CORROBORATION=2
CROWN_DET_MAX_HOSTS=5000
# Comma-separated process paths whose IN-PLACE encryption is authorized (AC-FP-02). Empty by default.
CROWN_DET_ALLOWLIST=

# --- Containment time-box (seconds) for human-gated destructive actions ---
CROWN_ACTION_ROLLBACK_SECONDS=300
